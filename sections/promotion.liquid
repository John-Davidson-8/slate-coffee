{{'component-promotion.css' | asset_url | stylesheet_tag}}

<style>
.promotion-container-{{section.id}} {
  background: {{section.settings.bg_color}};
}
.promotion-container-{{section.id}} h2,
.promotion-container-{{section.id}} div {
  color: {{section.settings.text_color}};
}
</style>

<div class="page-width promotion-container promotion-container-{{section.id}}">
  <h2 class="h1">{{section.settings.heading}}</h2>
  <div>{{section.settings.text}}</div>
  <a class="button" href="{{section.settings.btn_link}}">{{section.settings.btn_text}}</a>
</div>

{%  schema  %}
  {
    "name": "Promotion",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
         "default": "Get 20% off all sale items"
      },
      {
        "type": "text",
        "id": "text",
        "label": "Text",
         "default": "Use code EXTRA at Checkout"
      },
      {
        "type": "text",
        "id": "btn_text",
        "label": "Button Label",
        "default": "Shop Now"
      },
      {
        "type": "url",
        "id": "btn_link",
        "label": "Button link"
      },
      {
        "type": "color",
        "id": "bg_color",
        "label": "Background color",
        "default": "transparent"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text color",
        "default": "#000000"
      }
      


    ],
    "presets": [ 
      {"name": "Promotion"}
    ]
  }
{% endschema %}